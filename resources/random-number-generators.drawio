          <mxGeometry x="30" y="670" width="1210" height="410" as="geometry" />
        </mxCell>
        <mxCell id="44" value="{hashAlgorithm}  ·  hash function underlying Hash_DRBG or HMAC_DRBG" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="30" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="45" value="{cipherAlgorithm}  ·  block cipher underlying CTR_DRBG, Fortuna, or Yarrow generator" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="66" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="46" value="{securityStrength}  ·  integer (bits)  ·  target security level: 112 | 128 | 192 | 256" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="102" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="47" value="{predictionResistance}  ·  boolean  ·  forces live entropy reseed before every generate call" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="138" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="48" value="{derivationFunction}  ·  boolean  ·  CTR_DRBG DF: true (recommended) | false (noDF, not recommended)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="174" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="49" value="{reseedInterval}  ·  positive integer  ·  max generate calls before mandatory reseed (SP 800-90A: ≤2⁴⁸)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="210" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="50" value="{maxBitsPerRequest}  ·  integer (bits)  ·  hard upper bound per generate call (SP 800-90A: 2¹⁹ bits)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="30" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="51" value="{personalizationString}  ·  byte string  ·  optional caller-supplied domain separator at instantiation" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="66" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="52" value="{additionalInput}  ·  byte string  ·  optional per-call data mixed into DRBG state at generate / reseed" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="102" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="53" value="{entropyInputLength}  ·  integer (bits)  ·  min entropy bits at instantiation / reseed (≥ securityStrength)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="138" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="54" value="{nonceLength}  ·  integer (bits)  ·  instantiation nonce providing ≥ securityStrength/2 bits of entropy" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="174" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="55" value="&lt;b&gt;Fortuna fixed design parameters:&lt;/b&gt;  32 entropy pools (P0–P31)  ·  pool hash = SHA-256  ·  generator = AES-256-CTR  ·  max 2¹⁶ blocks per request  ·  pool-i used iff 2ⁱ | reseed-counter" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="250" width="1198" height="38" as="geometry" />
        </mxCell>
        <mxCell id="56" value="{minPoolSize}  ·  integer (bytes)  ·  Fortuna minimum pool-0 entropy before reseed is permitted; default 64 bytes" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="293" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="57" value="{poolCount}  ·  integer  ·  number of Fortuna entropy-accumulator pools (standard design: 32 pools P0–P31)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="293" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="58" value="{minEntropyBitsPerSample}  ·  real (bits/symbol)  ·  SP 800-90B: min-entropy H_min of each raw noise source sample" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="4" y="331" width="594" height="34" as="geometry" />
        </mxCell>
        <mxCell id="59" value="{conditioningComponent}  ·  algorithm ref  ·  SP 800-90B conditioning function applied to raw entropy (e.g. SHA-256, AES-CBC-MAC)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
          <mxGeometry x="603" y="331" width="600" height="34" as="geometry" />
        </mxCell>
        <mxCell id="60" value="{rbgConstruction}  ·  enumeration  ·  SP 800-90C RBG architecture type: DRBG | NRBG | DRBG+NRBG (deterministic, non-deterministic, or hybrid)" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;spacingLeft=6;whiteSpace=wrap;" parent="43" vertex="1">
